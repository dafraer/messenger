<!DOCTYPE html><html lang="en"><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Adrestalk Messenger</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Manrope:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "on-secondary-fixed": "#1a1c1c",
                      "inverse-surface": "#2f3131",
                      "tertiary-fixed": "#5e5e5e",
                      "on-surface-variant": "#474747",
                      "error-container": "#ffdad6",
                      "secondary-container": "#d4d4d4",
                      "surface-variant": "#e2e2e2",
                      "surface-container-low": "#f3f3f4",
                      "surface-container-highest": "#e2e2e2",
                      "on-tertiary-fixed": "#ffffff",
                      "on-background": "#1a1c1c",
                      "primary-container": "#3b3b3b",
                      "surface-bright": "#f9f9f9",
                      "primary-fixed-dim": "#474747",
                      "surface-tint": "#5e5e5e",
                      "on-tertiary-container": "#ffffff",
                      "surface-container": "#eeeeee",
                      "tertiary-fixed-dim": "#464747",
                      "on-error-container": "#410002",
                      "outline": "#777777",
                      "surface-container-lowest": "#ffffff",
                      "tertiary": "#3b3b3c",
                      "on-primary-container": "#ffffff",
                      "surface-dim": "#dadada",
                      "surface-container-high": "#e8e8e8",
                      "surface": "#f9f9f9",
                      "inverse-on-surface": "#f0f1f1",
                      "on-secondary-fixed-variant": "#3a3c3c",
                      "on-primary": "#e2e2e2",
                      "on-tertiary-fixed-variant": "#e4e2e2",
                      "on-surface": "#1a1c1c",
                      "error": "#ba1a1a",
                      "background": "#f9f9f9",
                      "on-error": "#ffffff",
                      "primary": "#000000",
                      "on-secondary": "#ffffff",
                      "on-primary-fixed-variant": "#e2e2e2",
                      "on-secondary-container": "#1a1c1c",
                      "inverse-primary": "#c6c6c6",
                      "primary-fixed": "#5e5e5e",
                      "secondary": "#5d5f5f",
                      "tertiary-container": "#747474",
                      "outline-variant": "#c6c6c6",
                      "on-tertiary": "#e4e2e2",
                      "secondary-fixed": "#c6c6c7",
                      "on-primary-fixed": "#ffffff",
                      "secondary-fixed-dim": "#aaabab"
              },
              "borderRadius": {
                      "DEFAULT": "0.25rem",
                      "lg": "0.5rem",
                      "xl": "0.75rem",
                      "full": "9999px"
              },
              "spacing": {},
              "fontFamily": {
                      "headline": [
                              "Manrope"
                      ],
                      "body": [
                              "Inter"
                      ],
                      "label": [
                              "Inter"
                      ]
              }
      },
          },
        }
      </script>
<style>
          .ghost-border {
              border: 1px solid rgba(198, 198, 198, 0.15); /* outline-variant at 15% */
          }
          .ambient-shadow {
              box-shadow: 0px 12px 32px rgba(26, 28, 28, 0.06);
          }
      </style>
</head>
<body class="bg-background text-on-surface font-body antialiased flex h-screen overflow-hidden">
<!-- SideNavBar (Shared Component) -->
<nav class="hidden md:flex flex-col py-8 px-4 gap-6 h-screen w-64 border-r border-zinc-100 dark:border-zinc-900 bg-zinc-50 dark:bg-zinc-950 font-['Manrope'] uppercase tracking-widest text-[10px]">
<div class="mb-12 px-4">
<div class="flex items-center gap-3 mb-2">
<div>
<h1 class="font-black text-lg text-black dark:text-white leading-tight" style="">ADRESTALK</h1>
<p class="text-zinc-500 tracking-wider text-[8px]" style=""><br></p>
</div>
</div>
</div>
<button class="w-full bg-primary text-on-primary py-3 rounded-md font-bold tracking-widest hover:opacity-90 transition-opacity mb-6 ambient-shadow" style="">
            NEW CONVERSATION
        </button>
<div class="flex flex-col gap-2 flex-grow">
<!-- Active Tab -->
<a class="flex items-center gap-4 px-4 py-3 bg-white dark:bg-zinc-900 text-black dark:text-white font-bold shadow-sm rounded-md scale-95 transition-all duration-150" href="#" style="">
<span class="material-symbols-outlined" style="font-variation-settings: &quot;FILL&quot; 1;">chat_bubble</span>
<span class="" style="">Adrestalk</span>
</a>
</div>
</nav>
<!-- Main Content Area -->
<main class="flex-1 flex flex-col h-screen relative bg-background">
<!-- Contact Info Header -->
<header class="absolute top-0 w-full z-50 bg-white/80 dark:bg-black/80 backdrop-blur-xl px-8 h-20 flex justify-between items-center transition-all">
<div class="flex items-center gap-4">
<!-- Back button for mobile -->
<button class="md:hidden text-primary hover:opacity-70 transition-opacity" style="">
<span class="material-symbols-outlined" style="">arrow_back</span>
</button>
<div>
<h2 class="font-headline font-bold text-lg text-primary tracking-tight" style="">Alexander Wright</h2>
</div>
</div>
</header>
<!-- Message List Area -->
<div class="flex-1 overflow-y-auto px-6 md:px-12 pt-28 pb-32 flex flex-col gap-6 scroll-smooth bg-surface-container-low">
<!-- Date Divider -->
<div class="flex justify-center my-6">
<span class="font-label text-xs text-outline uppercase tracking-widest bg-surface-container-low px-4" style="">TODAY</span>
</div>
<!-- Recipient Message Block -->
<div class="flex flex-col gap-2 items-start max-w-2xl">
<div class="flex items-end gap-3">
<div class="bg-surface-container-highest text-on-surface p-4 rounded-xl rounded-bl-none shadow-sm text-base leading-relaxed font-body" style="">
                        The latest draft looks solid. I’ve reviewed the margins on the secondary pages.
                    </div>
</div>
<div class="flex items-end gap-3">
<div class="bg-surface-container-highest text-on-surface p-4 rounded-xl rounded-bl-none shadow-sm text-base leading-relaxed font-body" style="">
                        We might need to adjust the tracking on the headline font, it feels slightly heavy. Thoughts?
                    </div>
</div>
<span class="font-label text-[10px] text-on-surface-variant ml-2 uppercase tracking-wider" style=""><br></span>
</div>
<!-- User Message Block -->
<div class="flex flex-col gap-2 items-end self-end max-w-2xl">
<div class="flex items-end gap-3 justify-end">
<div class="bg-primary text-on-primary p-4 rounded-xl rounded-br-none ambient-shadow text-base leading-relaxed font-body" style="">
                        Agreed on the tracking. I'll pull it back by 2% on the display tokens.
                    </div>
</div>
<div class="flex items-end gap-3 justify-end">
<div class="bg-primary text-on-primary p-4 rounded-xl rounded-br-none ambient-shadow text-base leading-relaxed font-body" style="">
                        Did you get a chance to look at the new ghost border spec?
                    </div>
</div>
<span class="font-label text-[10px] text-on-surface-variant mr-2 uppercase tracking-wider" style=""><br></span>
</div>
<!-- Recipient Message Block -->
<div class="flex flex-col gap-2 items-start max-w-2xl mt-8">
<div class="flex items-end gap-3">
<div class="bg-surface-container-highest text-on-surface p-4 rounded-xl rounded-bl-none shadow-sm text-base leading-relaxed font-body" style="">
                        Yes, the 15% opacity works perfectly against the surface background. Very clean.
                    </div>
</div>
<span class="font-label text-[10px] text-on-surface-variant ml-2 uppercase tracking-wider" style=""><br></span>
</div>
<!-- User Message Block -->
<div class="flex flex-col gap-2 items-end self-end max-w-2xl mt-4">
<div class="flex items-end gap-3 justify-end">
<div class="bg-primary text-on-primary p-4 rounded-xl rounded-br-none ambient-shadow text-base leading-relaxed font-body" style="">
                        Excellent. I'll finalize the push now.
                    </div>
</div>
<span class="font-label text-[10px] text-on-surface-variant mr-2 uppercase tracking-wider" style=""><br></span>
</div>
</div>
<!-- Input Area -->
<div class="absolute bottom-0 w-full bg-surface/90 backdrop-blur-md px-6 md:px-12 py-6 flex items-end gap-4 z-40">
<div class="flex-1 relative">
<textarea class="w-full bg-surface-container-lowest text-on-surface placeholder-outline font-body text-base rounded-md px-4 py-4 resize-none focus:outline-none focus:ring-0 border-0 border-b-2 border-transparent focus:border-primary transition-all shadow-sm max-h-32 overflow-y-auto" placeholder="Type a message..." rows="1" style="min-height: 56px;"></textarea>
</div>
<button class="bg-primary text-on-primary h-14 w-14 rounded-md flex items-center justify-center hover:opacity-90 transition-opacity flex-shrink-0 ambient-shadow" style="">
<span class="material-symbols-outlined" style="font-variation-settings: &quot;FILL&quot; 1;">send</span>
</button>
</div>
</main>
</body></html>