<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Architectural Messenger - Login</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Manrope:wght@400;600;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-secondary-fixed": "#1a1c1c",
                        "inverse-surface": "#2f3131",
                        "tertiary-fixed": "#5e5e5e",
                        "on-surface-variant": "#474747",
                        "error-container": "#ffdad6",
                        "secondary-container": "#d4d4d4",
                        "surface-variant": "#e2e2e2",
                        "surface-container-low": "#f3f3f4",
                        "surface-container-highest": "#e2e2e2",
                        "on-tertiary-fixed": "#ffffff",
                        "on-background": "#1a1c1c",
                        "primary-container": "#3b3b3b",
                        "surface-bright": "#f9f9f9",
                        "primary-fixed-dim": "#474747",
                        "surface-tint": "#5e5e5e",
                        "on-tertiary-container": "#ffffff",
                        "surface-container": "#eeeeee",
                        "tertiary-fixed-dim": "#464747",
                        "on-error-container": "#410002",
                        "outline": "#777777",
                        "surface-container-lowest": "#ffffff",
                        "tertiary": "#3b3b3c",
                        "on-primary-container": "#ffffff",
                        "surface-dim": "#dadada",
                        "surface-container-high": "#e8e8e8",
                        "surface": "#f9f9f9",
                        "inverse-on-surface": "#f0f1f1",
                        "on-secondary-fixed-variant": "#3a3c3c",
                        "on-primary": "#e2e2e2",
                        "on-tertiary-fixed-variant": "#e4e2e2",
                        "on-surface": "#1a1c1c",
                        "error": "#ba1a1a",
                        "background": "#f9f9f9",
                        "on-error": "#ffffff",
                        "primary": "#000000",
                        "on-secondary": "#ffffff",
                        "on-primary-fixed-variant": "#e2e2e2",
                        "on-secondary-container": "#1a1c1c",
                        "inverse-primary": "#c6c6c6",
                        "primary-fixed": "#5e5e5e",
                        "secondary": "#5d5f5f",
                        "tertiary-container": "#747474",
                        "outline-variant": "#c6c6c6",
                        "on-tertiary": "#e4e2e2",
                        "secondary-fixed": "#c6c6c7",
                        "on-primary-fixed": "#ffffff",
                        "secondary-fixed-dim": "#aaabab"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Manrope", "sans-serif"],
                        "body": ["Inter", "sans-serif"],
                        "label": ["Inter", "sans-serif"]
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-background text-on-surface font-body antialiased min-h-screen flex items-center justify-center p-4">
<!-- TopAppBar Suppressed as per Semantic Shell Mandate for linear/transactional pages (Login) -->
<!-- SideNavBar Suppressed as per Semantic Shell Mandate for linear/transactional pages (Login) -->
<main class="w-full max-w-[1200px] mx-auto flex flex-col items-center justify-center">
<!-- Form Section (Container Lowest on Background for Depth) -->
<section class="bg-surface-container-lowest p-10 lg:p-14 rounded-xl shadow-[0px_12px_32px_rgba(26,28,28,0.06)] w-full max-w-[480px]">
<div class="mb-12">
<h2 class="font-headline text-3xl font-bold text-primary mb-2" style="">Sign In</h2>
<p class="font-label text-sm text-on-surface-variant uppercase tracking-widest" style="">Access your workspace</p>
</div>
<form class="space-y-8 flex flex-col">
<!-- Input Group -->
<div class="space-y-6">
<div>
<label class="block font-label text-xs uppercase tracking-widest text-on-surface-variant mb-2" for="email" style="">Email Address</label>
<input class="w-full bg-surface-container-lowest text-on-surface border-0 border-b-2 border-outline-variant focus:border-primary focus:ring-0 px-0 py-3 font-body text-base transition-colors placeholder:text-outline" id="email" placeholder="name@company.com" type="email"/>
</div>
<div>
<div class="flex justify-between items-center mb-2">
<label class="block font-label text-xs uppercase tracking-widest text-on-surface-variant" for="password" style="">Password</label>
<a class="font-label text-xs text-on-surface-variant hover:text-primary underline transition-colors" href="#" style="">Forgot?</a>
</div>
<input class="w-full bg-surface-container-lowest text-on-surface border-0 border-b-2 border-outline-variant focus:border-primary focus:ring-0 px-0 py-3 font-body text-base transition-colors placeholder:text-outline" id="password" placeholder="••••••••" type="password"/>
</div>
</div>
<!-- Actions -->
<div class="flex flex-col gap-4 pt-4">
<button class="w-full bg-primary text-on-primary font-headline font-bold text-lg py-4 px-6 rounded-lg hover:bg-primary-container transition-colors shadow-sm flex items-center justify-center gap-2" style="" type="submit">Login<br/><span aria-hidden="true" class="material-symbols-outlined text-xl" data-icon="arrow_forward" style="">arrow_forward</span>
</button>
<button class="w-full bg-transparent border border-outline-variant/15 text-primary font-headline font-semibold text-lg py-4 px-6 rounded-lg hover:bg-surface-container-low transition-colors" style="" type="button">
                        Create Account
                    </button>
</div>
</form>
</section>
</main>
</body></html>